TYPE=llamenos
DOMAIN=hotline.example.com
LETS_ENCRYPT_ENV=production

# ── Secret versions ────────────────────────────────────────
# Generate with: abra app secret generate -a <app-name>
SECRET_HMAC_SECRET_VERSION=v1       # length=64 charset=hex
SECRET_SERVER_NOSTR_VERSION=v1      # length=64 charset=hex
SECRET_DB_PASSWORD_VERSION=v1       # length=32 charset=alnum
SECRET_MINIO_ACCESS_VERSION=v1      # length=20 charset=alnum
SECRET_MINIO_SECRET_VERSION=v1      # length=40 charset=alnum

# ── App image ──────────────────────────────────────────────
# LLAMENOS_TAG=latest

# ── App configuration ──────────────────────────────────────
# HOTLINE_NAME=Hotline
# ADMIN_PUBKEY=                      # Set after first login via setup wizard
# ADMIN_DECRYPTION_PUBKEY=
# DEMO_MODE=true                     # Uncomment to enable demo mode

# ── Database ───────────────────────────────────────────────
# PG_POOL_SIZE=10

# ── Object storage ─────────────────────────────────────────
# MINIO_BUCKET=llamenos-files

# ── Telephony ──────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Optional services (add to COMPOSE_FILE) ───────────────
#
# Transcription:
#   COMPOSE_FILE="compose.yml:compose.transcription.yml"
#   WHISPER_MODEL=Systran/faster-whisper-base
#   WHISPER_DEVICE=cpu
#
# Asterisk PBX:
#   COMPOSE_FILE="compose.yml:compose.asterisk.yml"
#   SECRET_ARI_PASSWORD_VERSION=v1
#   SECRET_BRIDGE_SECRET_VERSION=v1
#
# Signal messaging:
#   COMPOSE_FILE="compose.yml:compose.signal.yml"
#
# Multiple overlays:
#   COMPOSE_FILE="compose.yml:compose.transcription.yml:compose.signal.yml"
